# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# OpenAI — AI agent chat (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...your-openai-key

# Resend — Transactional emails (https://resend.com/api-keys)
RESEND_API_KEY=re_...your-resend-key

# Site URL — Used for calendar links, emails, and OG images
NEXT_PUBLIC_SITE_URL=https://experiences.timesgroup.com
